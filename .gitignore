checkpoints/
logs/
outputs/
data/
deploy/

# Jupyter
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# Test & coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type-checker caches
.mypy_cache/
.pyright/

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Temporary files
*.tmp
*.bak
